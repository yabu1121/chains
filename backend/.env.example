# Copy to .env and adjust. The app reads these from the process environment.
APP_ENV=development
HTTP_ADDR=:8080
DATABASE_URL=postgres://chains:chains@localhost:5432/chains?sslmode=disable
REDIS_ADDR=localhost:6379
REDIS_DB=0
# Required when APP_ENV is not development/test.
JWT_SECRET=dev-insecure-secret-change-me
JWT_TTL=24h
CORS_ORIGINS=http://localhost:3000
CACHE_TTL=5m
