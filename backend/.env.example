# Chains backend configuration. Copy to .env (gitignored) and fill in for your
# environment. Values below are production-oriented; for local development use
# `make backend-dev` (the devserver sets APP_ENV=development itself).

# Environment. Anything other than "development"/"test" is treated as
# production: a real JWT_SECRET becomes mandatory, and migrations/Redis are
# required by default. If APP_ENV is unset it is treated as production
# (fail-closed) rather than silently using the insecure dev secret.
APP_ENV=production

# HTTP listen address.
HTTP_ADDR=:8080

# --- Secrets (REQUIRED in production) ---------------------------------------
# HS256 signing secret. Must be at least 32 bytes outside development.
# Generate one with: openssl rand -base64 48
JWT_SECRET=
# Access-token lifetime.
JWT_TTL=24h

# --- Database ---------------------------------------------------------------
# Use sslmode=require (or verify-full) in production.
DATABASE_URL=postgres://chains:chains@db.example.com:5432/chains?sslmode=require
# Connection pool tuning.
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=10m
# Run schema migrations on API start-up. Off in production — run cmd/migrate as
# a separate deploy step (make backend-migrate) instead.
AUTO_MIGRATE=false

# --- Redis ------------------------------------------------------------------
REDIS_ADDR=redis.example.com:6379
REDIS_DB=0
# Require Redis (fail to start if unreachable). Keep true for multi-instance
# deploys so cache invalidation propagates across instances.
REQUIRE_REDIS=true
# Shared cache TTL.
CACHE_TTL=5m

# --- Avatars ----------------------------------------------------------------
# Where avatar image bytes are stored: "postgres" (in the user_avatars table)
# or "fs" (a local directory standing in for object storage). A production
# object-storage/S3 backend can be added behind the same interface.
AVATAR_STORAGE=postgres
# Base directory when AVATAR_STORAGE=fs.
AVATAR_FS_DIR=

# --- CORS & cookies ---------------------------------------------------------
# Comma-separated list of allowed front-end origins. Do NOT use "*" in
# production; list the exact site origin(s).
CORS_ORIGINS=https://chains.example.com
# Auth-cookie SameSite policy. "lax" when the site and API share a registrable
# domain (e.g. app.example.com + api.example.com). "none" for cross-site hosts
# (e.g. separate *.run.app URLs); "none" implies Secure.
COOKIE_SAMESITE=lax
# Mark auth cookies Secure (HTTPS-only). Defaults to true outside development.
COOKIE_SECURE=true

# --- TLS (optional) ---------------------------------------------------------
# Set both to terminate TLS in-process; otherwise TLS is terminated upstream.
TLS_CERT_FILE=
TLS_KEY_FILE=
